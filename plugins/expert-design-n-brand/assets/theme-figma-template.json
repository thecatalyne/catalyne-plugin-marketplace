{
  "$schema": "https://tokens-studio.github.io/schemas/dtcg.json",
  "$description": "{{ brand_name }} — Figma tokens for Tokens Studio import. Import via the Tokens Studio plugin (Figma → Plugins → Tokens Studio → Tools → Load from JSON). This file is generated by /brand-export from tokens.json + surface-translations.yaml; do not hand-edit.",
  "meta": {
    "brand": "{{ brand_name }}",
    "version": "{{ version_semver }}",
    "generated": "{{ generated_date }}",
    "source": "tokens.json + surface-translations.yaml"
  },
  "color": {
    "primitive": {
      "$description": "Brand's core palette roles — {{ brand_name }} uses {{ palette_core_count }} roles: {{ palette_core_names }}.",
      "$type": "color",
      "$value_placeholder": "Populated by brand-export from system.color.palette.core[]"
    },
    "anchors": {
      "$description": "Optional named-hex set distinct from core roles. Populated only if the brand has named hexes beyond its functional roles.",
      "$type": "color",
      "$value_placeholder": "Populated from system.color.palette.anchors[]"
    },
    "scale": {
      "$description": "10-step scales per color family (brand, neutral, accent, plus any brand-specific named scale).",
      "$type": "color",
      "$value_placeholder": "Populated from system.color.palette.scales[]"
    },
    "semantic": {
      "$description": "Semantic role tokens — use these in components, not the primitives directly.",
      "text-primary":   { "$value": "{color.primitive.{{ role_text_primary }}.hex}",   "$type": "color" },
      "text-secondary": { "$value": "{color.primitive.{{ role_text_secondary }}.hex}", "$type": "color" },
      "text-tertiary":  { "$value": "{color.primitive.{{ role_text_tertiary }}.hex}",  "$type": "color" },
      "text-disabled":  { "$value": "{color.primitive.{{ role_text_disabled }}.hex}",  "$type": "color" },
      "text-inverse":   { "$value": "{color.primitive.{{ role_text_inverse }}.hex}",   "$type": "color" },
      "text-link":      { "$value": "{color.primitive.{{ role_link }}.hex}",           "$type": "color" },
      "surface":        { "$value": "{color.primitive.{{ role_surface }}.hex}",        "$type": "color" },
      "bg":             { "$value": "{color.primitive.{{ role_bg }}.hex}",             "$type": "color" },
      "border":         { "$value": "{color.primitive.{{ role_border }}.hex}",         "$type": "color" },
      "border-strong":  { "$value": "{color.primitive.{{ role_border_strong }}.hex}",  "$type": "color" },
      "success":        { "$value": "{{ semantic_success_hex }}",                       "$type": "color" },
      "warning":        { "$value": "{{ semantic_warning_hex }}",                       "$type": "color" },
      "error":          { "$value": "{{ semantic_error_hex }}",                         "$type": "color" },
      "info":           { "$value": "{{ semantic_info_hex }}",                          "$type": "color" }
    }
  },
  "typography": {
    "family": {
      "heading": { "$value": "{{ heading_family }}", "$type": "fontFamily" },
      "body":    { "$value": "{{ body_family }}",    "$type": "fontFamily" }
    },
    "weight": {
      "light":    { "$value": 300, "$type": "fontWeight" },
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" },
      "heading-default": { "$value": "{{ heading_weight }}", "$type": "fontWeight" },
      "body-default":    { "$value": "{{ body_weight }}",    "$type": "fontWeight" }
    },
    "size": {
      "display": { "$value": "{{ size_display }}", "$type": "dimension" },
      "h1":      { "$value": "{{ size_h1 }}",      "$type": "dimension" },
      "h2":      { "$value": "{{ size_h2 }}",      "$type": "dimension" },
      "h3":      { "$value": "{{ size_h3 }}",      "$type": "dimension" },
      "body":    { "$value": "{{ size_body }}",    "$type": "dimension" },
      "small":   { "$value": "{{ size_small }}",   "$type": "dimension" }
    },
    "lineHeight": {
      "heading": { "$value": "{{ lineheight_heading }}", "$type": "number" },
      "body":    { "$value": "{{ lineheight_body }}",    "$type": "number" }
    }
  },
  "spacing": {
    "$type": "dimension",
    "$description": "Populated from system.typography.scale.sizes[] — see brand-guidelines.html §6 for the full scale."
  },
  "radius": {
    "interactive": { "$value": "{{ radius_interactive }}", "$type": "dimension" },
    "card":        { "$value": "{{ radius_card }}",        "$type": "dimension" }
  },
  "shadow": {
    "sm": { "$value": "{{ shadow_sm }}", "$type": "shadow" },
    "md": { "$value": "{{ shadow_md }}", "$type": "shadow" },
    "lg": { "$value": "{{ shadow_lg }}", "$type": "shadow" }
  }
}

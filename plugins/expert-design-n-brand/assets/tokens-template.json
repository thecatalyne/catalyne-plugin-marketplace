{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Brand design tokens — DTCG W3C 2025.10 format. Generated by expert-design-n-brand plugin. Three-tier (primitive → semantic → component) with explicit modes for light/dark. Every leaf has $value, $type, $description. Brand-specific expressive tokens (gradients, motifs, named flourish moments) live in the optional `extensions` namespace and never replace standard role names.",

  "$meta": {
    "brand":       { "$value": "", "$type": "string" },
    "version":     { "$value": "", "$type": "string" },
    "generated":   { "$value": "", "$type": "string" },
    "source":      { "$value": "brand-identity.yaml", "$type": "string" },
    "notes":       { "$value": "Palette role keys (background/primary/neutral/accent) are variable-N; adapt to brand. Primitive tier is mode-invariant. The `extensions` namespace is optional — tools that don't recognize it ignore it; brand-aware tools consume it.", "$type": "string" }
  },

  "primitive": {
    "color": {
      "palette": {
        "background": { "$value": "", "$type": "color", "$description": "Primary light-mode surface (60%)" },
        "primary":    { "$value": "", "$type": "color", "$description": "Default brand color, most-used (30%)" },
        "neutral":    { "$value": "", "$type": "color", "$description": "Primary text / foreground anchor of the system" },
        "accent":     { "$value": "", "$type": "color", "$description": "Catalyst/energy accent (10%)" }
      },
      "anchors": {
        "__note": "Optional named-hex set distinct from core roles. Useful when a brand has more named hexes than functional roles (e.g. 8–10 named hexes vs 3–4 roles). Keep kebab-case keys.",
        "anchor-1": { "$value": "", "$type": "color", "$description": "" }
      },
      "scales": {
        "__note": "10-step scales per color family. Standard families: brand, neutral, accent. Add additional named scales (indigo, gold, etc.) under any free-form key as needed.",
        "brand": {
          "50":  { "$value": "", "$type": "color" }, "100": { "$value": "", "$type": "color" }, "200": { "$value": "", "$type": "color" }, "300": { "$value": "", "$type": "color" }, "400": { "$value": "", "$type": "color" }, "500": { "$value": "", "$type": "color" }, "600": { "$value": "", "$type": "color" }, "700": { "$value": "", "$type": "color" }, "800": { "$value": "", "$type": "color" }, "900": { "$value": "", "$type": "color" }
        },
        "neutral": {
          "50":  { "$value": "", "$type": "color" }, "100": { "$value": "", "$type": "color" }, "200": { "$value": "", "$type": "color" }, "300": { "$value": "", "$type": "color" }, "400": { "$value": "", "$type": "color" }, "500": { "$value": "", "$type": "color" }, "600": { "$value": "", "$type": "color" }, "700": { "$value": "", "$type": "color" }, "800": { "$value": "", "$type": "color" }, "900": { "$value": "", "$type": "color" }
        },
        "accent": {
          "50":  { "$value": "", "$type": "color" }, "100": { "$value": "", "$type": "color" }, "200": { "$value": "", "$type": "color" }, "300": { "$value": "", "$type": "color" }, "400": { "$value": "", "$type": "color" }, "500": { "$value": "", "$type": "color" }, "600": { "$value": "", "$type": "color" }, "700": { "$value": "", "$type": "color" }, "800": { "$value": "", "$type": "color" }, "900": { "$value": "", "$type": "color" }
        }
      }
    },

    "typography": {
      "fontFamily": {
        "heading": { "$value": [], "$type": "fontFamily", "$description": "Fallback chain as array of family names" },
        "body":    { "$value": [], "$type": "fontFamily" },
        "mono":    { "$value": ["ui-monospace", "monospace"], "$type": "fontFamily" }
      },
      "fontSize": {
        "caption": { "$value": "0.64rem",  "$type": "dimension" },
        "small":   { "$value": "0.80rem",  "$type": "dimension" },
        "body":    { "$value": "1rem",     "$type": "dimension" },
        "lead":    { "$value": "1.25rem",  "$type": "dimension" },
        "h4":      { "$value": "1.563rem", "$type": "dimension" },
        "h3":      { "$value": "1.953rem", "$type": "dimension" },
        "h2":      { "$value": "2.441rem", "$type": "dimension" },
        "h1":      { "$value": "3.052rem", "$type": "dimension" },
        "display": { "$value": "3.815rem", "$type": "dimension" }
      },
      "fontWeight": {
        "light":    { "$value": 300, "$type": "fontWeight", "$description": "Use as default heading weight when brand voice is authoritative/editorial. Adjust per brand." },
        "regular":  { "$value": 400, "$type": "fontWeight", "$description": "Default body weight." },
        "medium":   { "$value": 500, "$type": "fontWeight" },
        "semibold": { "$value": 600, "$type": "fontWeight" },
        "bold":     { "$value": 700, "$type": "fontWeight" }
      },
      "scale": {
        "ratio": { "$value": 1.250, "$type": "number", "$description": "Modular scale ratio — adjust per brand: minor-third (1.2), major-third (1.250), perfect-fourth (1.333), etc." }
      },
      "letterSpacing": {
        "tight":  { "$value": "-0.02em", "$type": "dimension", "$description": "Use on large headings/display." },
        "normal": { "$value": "0",       "$type": "dimension" },
        "wide":   { "$value": "0.08em",  "$type": "dimension", "$description": "Use on eyebrows / all-caps labels." }
      },
      "lineHeight": {
        "tight":  { "$value": 1.2, "$type": "number" },
        "snug":   { "$value": 1.4, "$type": "number" },
        "normal": { "$value": 1.5, "$type": "number" }
      }
    },

    "space": {
      "1":  { "$value": "0.25rem", "$type": "dimension", "$description": "4px — hairline" },
      "2":  { "$value": "0.5rem",  "$type": "dimension", "$description": "8px" },
      "3":  { "$value": "0.75rem", "$type": "dimension", "$description": "12px" },
      "4":  { "$value": "1rem",    "$type": "dimension", "$description": "16px — base" },
      "6":  { "$value": "1.5rem",  "$type": "dimension" },
      "8":  { "$value": "2rem",    "$type": "dimension" },
      "12": { "$value": "3rem",    "$type": "dimension" },
      "16": { "$value": "4rem",    "$type": "dimension" },
      "24": { "$value": "6rem",    "$type": "dimension" },
      "32": { "$value": "8rem",    "$type": "dimension" }
    },

    "radius": {
      "none":        { "$value": "0",      "$type": "dimension" },
      "sm":          { "$value": "0.25rem","$type": "dimension", "$description": "Subtle — 4px" },
      "md":          { "$value": "0.5rem", "$type": "dimension", "$description": "Default — 8px" },
      "lg":          { "$value": "0.75rem","$type": "dimension", "$description": "Cards — 12px" },
      "xl":          { "$value": "1rem",   "$type": "dimension", "$description": "Pronounced — 16px" },
      "pill":        { "$value": "9999px", "$type": "dimension", "$description": "Badges, chips, tags only" },
      "interactive": { "$value": "{primitive.radius.md}", "$type": "dimension", "$description": "Semantic alias — buttons, inputs" },
      "card":        { "$value": "{primitive.radius.lg}", "$type": "dimension", "$description": "Semantic alias — elevated surfaces" }
    },

    "shadow": {
      "sm": { "$value": "0 1px 2px rgba(0,0,0,0.05)",                                 "$type": "shadow", "$description": "Layer 1 — subtle elevation" },
      "md": { "$value": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)", "$type": "shadow", "$description": "Layer 2 — cards, default elevation" },
      "lg": { "$value": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)", "$type": "shadow", "$description": "Layer 3 — modals, popovers" },
      "xl": { "$value": "0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1)", "$type": "shadow", "$description": "Layer 4 — overlays, dropdowns" }
    },

    "borderWidth": {
      "none":    { "$value": "0",   "$type": "dimension" },
      "thin":    { "$value": "1px", "$type": "dimension" },
      "default": { "$value": "{primitive.borderWidth.thin}", "$type": "dimension", "$description": "Default border weight." },
      "thick":   { "$value": "2px", "$type": "dimension" },
      "heavy":   { "$value": "4px", "$type": "dimension" }
    },

    "opacity": {
      "0":   { "$value": 0,    "$type": "number" },
      "5":   { "$value": 0.05, "$type": "number" },
      "10":  { "$value": 0.10, "$type": "number" },
      "20":  { "$value": 0.20, "$type": "number" },
      "40":  { "$value": 0.40, "$type": "number" },
      "60":  { "$value": 0.60, "$type": "number" },
      "80":  { "$value": 0.80, "$type": "number" },
      "100": { "$value": 1.00, "$type": "number" }
    },

    "zIndex": {
      "base":     { "$value": 0,    "$type": "number" },
      "dropdown": { "$value": 1000, "$type": "number" },
      "sticky":   { "$value": 1100, "$type": "number" },
      "overlay":  { "$value": 1200, "$type": "number" },
      "modal":    { "$value": 1300, "$type": "number" },
      "toast":    { "$value": 1400, "$type": "number" },
      "tooltip":  { "$value": 1500, "$type": "number" }
    },

    "breakpoint": {
      "sm":  { "$value": "640px",  "$type": "dimension", "$description": "Mobile landscape / large phone" },
      "md":  { "$value": "768px",  "$type": "dimension", "$description": "Tablet portrait" },
      "lg":  { "$value": "1024px", "$type": "dimension", "$description": "Tablet landscape / small desktop" },
      "xl":  { "$value": "1280px", "$type": "dimension", "$description": "Desktop" },
      "2xl": { "$value": "1536px", "$type": "dimension", "$description": "Large desktop" }
    },

    "motion": {
      "easing": {
        "linear":      { "$value": "linear",                              "$type": "cubicBezier" },
        "standard":    { "$value": "cubic-bezier(0, 0, 0.2, 1)",          "$type": "cubicBezier", "$description": "Ease-out — default UI transitions" },
        "ease-in":     { "$value": "cubic-bezier(0.4, 0, 1, 1)",          "$type": "cubicBezier", "$description": "Best for elements exiting" },
        "ease-in-out": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",        "$type": "cubicBezier", "$description": "Smooth both ends — moving/transforming" },
        "spring":      { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",   "$type": "cubicBezier", "$description": "Overshoots then settles — playful, energetic" }
      },
      "duration": {
        "instant": { "$value": "100ms", "$type": "duration" },
        "fast":    { "$value": "200ms", "$type": "duration" },
        "normal":  { "$value": "300ms", "$type": "duration" },
        "slow":    { "$value": "500ms", "$type": "duration" }
      }
    }
  },

  "semantic": {
    "$description": "Role-based tokens. Multi-mode via .light / .dark keys. Standard role set: bg, surface, text-primary, text-secondary, text-tertiary, text-inverse, text-disabled, border, border-strong, border-focus, link, link-hover.",

    "light": {
      "color": {
        "bg":              { "$value": "{primitive.color.palette.background}",  "$type": "color", "$description": "Page background" },
        "surface":         { "$value": "{primitive.color.scales.neutral.50}",   "$type": "color", "$description": "Cards, elevated panels — brighter than ground" },
        "surface-elevated":{ "$value": "{primitive.color.scales.neutral.50}",   "$type": "color", "$description": "Higher-elevation surface (modals, popovers)" },
        "text-primary":    { "$value": "{primitive.color.scales.neutral.900}",  "$type": "color", "$description": "Primary body text — black or very-dark neutral for legibility" },
        "text-secondary":  { "$value": "{primitive.color.scales.neutral.700}",  "$type": "color", "$description": "Subheads, meta" },
        "text-tertiary":   { "$value": "{primitive.color.scales.neutral.500}",  "$type": "color", "$description": "Quotes, captions, deprecated meta" },
        "text-disabled":   { "$value": "{primitive.color.scales.neutral.400}",  "$type": "color", "$description": "Disabled state text" },
        "text-inverse":    { "$value": "{primitive.color.palette.background}",  "$type": "color", "$description": "Text on dark surfaces" },
        "border":          { "$value": "{primitive.color.scales.neutral.200}",  "$type": "color" },
        "border-strong":   { "$value": "{primitive.color.scales.neutral.300}",  "$type": "color" },
        "border-focus":    { "$value": "{primitive.color.scales.brand.500}",    "$type": "color", "$description": "Form focus ring" },
        "link":            { "$value": "{primitive.color.scales.brand.600}",    "$type": "color", "$description": "Verify WCAG AA contrast against bg" },
        "link-hover":      { "$value": "{primitive.color.scales.brand.700}",    "$type": "color" }
      }
    },

    "dark": {
      "color": {
        "bg":              { "$value": "{primitive.color.scales.neutral.900}",  "$type": "color", "$description": "Dark mode ground" },
        "surface":         { "$value": "{primitive.color.scales.neutral.800}",  "$type": "color", "$description": "Lifted dark surface" },
        "surface-elevated":{ "$value": "{primitive.color.scales.neutral.700}",  "$type": "color" },
        "text-primary":    { "$value": "{primitive.color.scales.neutral.50}",   "$type": "color" },
        "text-secondary":  { "$value": "{primitive.color.scales.neutral.300}",  "$type": "color" },
        "text-tertiary":   { "$value": "{primitive.color.scales.neutral.500}",  "$type": "color" },
        "text-disabled":   { "$value": "{primitive.color.scales.neutral.600}",  "$type": "color" },
        "text-inverse":    { "$value": "{primitive.color.scales.neutral.900}",  "$type": "color" },
        "border":          { "$value": "{primitive.color.scales.neutral.700}",  "$type": "color" },
        "border-strong":   { "$value": "{primitive.color.scales.neutral.600}",  "$type": "color" },
        "border-focus":    { "$value": "{primitive.color.scales.brand.400}",    "$type": "color" },
        "link":            { "$value": "{primitive.color.scales.brand.400}",    "$type": "color" },
        "link-hover":      { "$value": "{primitive.color.scales.brand.300}",    "$type": "color" }
      }
    },

    "status": {
      "$description": "Mode-invariant semantic statuses.",
      "success": { "$value": "#16A34A", "$type": "color" },
      "warning": { "$value": "",        "$type": "color", "$description": "Typically brand's amber/warm hex; falls back to #D97706 if unspecified" },
      "error":   { "$value": "",        "$type": "color", "$description": "Typically brand's red/flame hex; falls back to #DC2626 if unspecified" },
      "info":    { "$value": "",        "$type": "color", "$description": "Typically brand's teal/cool hex; falls back to #0EA5E9 if unspecified" }
    },

    "elevation": {
      "$description": "Bind components to levels, not to raw shadow values.",
      "0-flat":  { "$value": "none",                       "$type": "shadow", "$description": "Flat surface" },
      "1-card":  { "$value": "{primitive.shadow.sm}",      "$type": "shadow", "$description": "Cards, default elevation" },
      "2-modal": { "$value": "{primitive.shadow.lg}",      "$type": "shadow", "$description": "Modals, popovers" },
      "3-overlay":{ "$value": "{primitive.shadow.xl}",     "$type": "shadow", "$description": "Overlays, dropdowns" }
    },

    "opacity": {
      "$description": "Semantic opacity aliases.",
      "disabled": { "$value": "{primitive.opacity.40}", "$type": "number" },
      "muted":    { "$value": "{primitive.opacity.60}", "$type": "number" },
      "scrim":    { "$value": "{primitive.opacity.40}", "$type": "number", "$description": "Modal backdrop" }
    }
  },

  "component": {
    "button": {
      "primary": {
        "bg":     { "$value": "{primitive.color.palette.primary}",        "$type": "color" },
        "fg":     { "$value": "{semantic.light.color.text-inverse}",      "$type": "color", "$description": "Verify WCAG AA against bg" },
        "radius": { "$value": "{primitive.radius.interactive}",           "$type": "dimension" }
      },
      "secondary": {
        "bg":     { "$value": "transparent",                              "$type": "color" },
        "fg":     { "$value": "{primitive.color.palette.primary}",        "$type": "color" },
        "border": { "$value": "{primitive.color.palette.primary}",        "$type": "color" },
        "radius": { "$value": "{primitive.radius.interactive}",           "$type": "dimension" }
      },
      "accent": {
        "bg":     { "$value": "{primitive.color.palette.accent}",         "$type": "color" },
        "fg":     { "$value": "{semantic.light.color.text-primary}",      "$type": "color" },
        "radius": { "$value": "{primitive.radius.interactive}",           "$type": "dimension" }
      },
      "ghost": {
        "bg":     { "$value": "transparent",                              "$type": "color" },
        "fg":     { "$value": "{semantic.light.color.text-secondary}",    "$type": "color" },
        "radius": { "$value": "{primitive.radius.interactive}",           "$type": "dimension" }
      }
    },

    "badge": {
      "aaa":  { "bg": { "$value": "#16A34A", "$type": "color" }, "fg": { "$value": "#FFFFFF", "$type": "color" } },
      "aa":   { "bg": { "$value": "#2563EB", "$type": "color" }, "fg": { "$value": "#FFFFFF", "$type": "color" } },
      "fail": { "bg": { "$value": "#DC2626", "$type": "color" }, "fg": { "$value": "#FFFFFF", "$type": "color" } }
    },

    "card": {
      "radius": { "$value": "{primitive.radius.card}",          "$type": "dimension" },
      "shadow": { "$value": "{semantic.elevation.1-card}",      "$type": "shadow" },
      "bg":     { "$value": "{semantic.light.color.surface}",   "$type": "color" },
      "border": { "$value": "{semantic.light.color.border}",    "$type": "color" }
    },

    "input": {
      "radius":       { "$value": "{primitive.radius.interactive}",        "$type": "dimension" },
      "border":       { "$value": "{semantic.light.color.border-strong}",  "$type": "color" },
      "border-focus": { "$value": "{semantic.light.color.border-focus}",   "$type": "color" },
      "border-error": { "$value": "{semantic.status.error}",               "$type": "color" }
    }
  },

  "extensions": {
    "$description": "Optional brand-expressive layer above the standard floor. Adds named gradients, signature motion flourishes, and motif systems on top of the canonical primitive/semantic/component tokens. Tools that don't recognize this namespace ignore it; brand-aware tools consume it.",

    "color": {
      "expressions": {
        "$description": "Optional named multi-modal flourish gradients / spectral ranges. Brand-aware renderers use these for signature visual moments. Use ONLY these + extensions.color.gradients for gradient fills — custom ad-hoc gradients are forbidden.",
        "default": { "$value": "", "$type": "gradient", "$description": "" }
      },
      "gradients": {
        "$description": "Optional named concrete gradients for exact reproduction. Each entry has direction + stops."
      },
      "flourish-glow": {
        "$value": "",
        "$type": "shadow",
        "$description": "Optional glow shadow for signature flourish moments — hero hover states, marquee elements. Brand-specific, never structural elevation."
      }
    },

    "motion": {
      "$description": "Brand aliases on top of canonical motion primitives.",
      "easing": {
        "flourish": { "$value": "{primitive.motion.easing.spring}", "$type": "cubicBezier", "$description": "Brand alias for spring easing — used in flourish moments." }
      }
    },

    "elevation": {
      "$description": "Brand-specific elevation that lifts a flourish glow above standard elevation tiers.",
      "flourish": { "$value": "{extensions.color.flourish-glow}", "$type": "shadow", "$description": "Optional — flourish glow elevation tier." }
    },

    "form": {
      "$description": "Signature visual elements — motifs, hero shapes, etc.",
      "motifs": {
        "$description": "Variable-N named decorative/structural shapes with semantic intent. Each entry should declare {name, description, svg_hint?, asset_path?, intent?}."
      },
      "hero-motif": {
        "$description": "Optional principal signature motif used in hero panels. {name, description, svg_hint?, asset_path?}."
      }
    }
  },

  "platform": {
    "$description": "Per-surface theme rendering is driven by `surface-translations.yaml`. This `platform` block is for one-off overrides only — most brands leave it empty and declare new surfaces in surface-translations.yaml.",
    "__note": "Empty by default. Populate only if a brand needs a surface-specific override that surface-translations.yaml doesn't already produce."
  }
}
